        private readonly Dictionary<string, string> _reports = new Dictionary<string, string>
        {
            ["usuarios"] = @"
                SELECT u.id_usuario, CONCAT(u.nombre, ' ', u.apellido) AS nombre_completo,
                       u.correo, r.nombre_rol, u.estado, u.fecha_creacion
                FROM usuarios u
